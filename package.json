{
	"name": "razorpay-poc",
	"version": "1.0.0",
	"description": "A proof of concept for Razorpay payment integration with Node.js v24, Express.js, PostgreSQL, Docker, and pgAdmin.",
	"type": "module",
	"main": "dist/server.js",
	"packageManager": "pnpm@10.8.1",
	"engines": {
		"node": ">=24.0.0"
	},
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"start": "node --env-file-if-exists=.env dist/server.js",
		"dev": "node --env-file-if-exists=.env --watch --experimental-strip-types src/server.ts",
		"dev:node-watch": "pnpm build && node --env-file-if-exists=.env --watch dist/server.js",
		"typecheck": "tsc --noEmit",
		"test": "node --env-file-if-exists=.env --experimental-strip-types --test src/**/*.test.ts",
		"test:watch": "node --env-file-if-exists=.env --watch --experimental-strip-types --test src/**/*.test.ts"
	},
	"dependencies": {
		"express": "^5.2.1",
		"pg": "^8.20.0",
		"razorpay": "^2.9.6"
	},
	"devDependencies": {
		"@types/express": "^5.0.6",
		"@types/node": "^25.5.0",
		"@types/pg": "^8.18.0",
		"typescript": "^5.9.3"
	},
	"keywords": [
		"razorpay",
		"nodejs",
		"express",
		"postgresql",
		"docker"
	],
	"author": "chaluvadis",
	"license": "MIT"
}
